#Mind's Dilation (G-retest 2026-06-11): opponent's first spell each turn ->
#ingest 1 (exile their library top) -> P1 may cast the exiled card free.
#Driving here is believed right (turn-cross: P2 taps myr, shocks P1's face
#- shock CAST+RESOLVED, life 18 confirmed) but the @movedto(*|opponentstack)
#trigger NEVER FIRES: zero StackAbility from Mind's Dilation in the log.
[INIT]
firstmain
[PLAYER1]
inplay:mind's dilation
[PLAYER2]
inplay:iron myr
hand:shock
library:eager cadet,wind drake,grizzly bears
[DO]
goto end
goto firstmain
iron myr
shock
p1
goto firstmain
choice 0
goto firstmain
choice 0
goto firstmain
goto firstmain
goto end
[ASSERT]
ENDOFTURN
[PLAYER1]
inplay:mind's dilation,wind drake
life:18
[PLAYER2]
inplay:iron myr
graveyard:shock
hand:grizzly bears
library:*
tappedinplay:1
[END]
