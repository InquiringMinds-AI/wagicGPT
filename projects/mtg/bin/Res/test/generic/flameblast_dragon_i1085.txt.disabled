#Flameblast Dragon (#1085 "with only red mana doesn't work") - PARKED,
#map sharpened 2026-06-11 (post 22 engine rounds). The DRIVING is now
#solved up to the payment: distinct-name rocks (two same-named myrs
#always click the FIRST instance), taps via the attackers-step menu
#(click myr -> choice 1), trigger fires, may accepted (choice 0,
#doReactTo). THE WEDGE: pay({X}{R}) then opens an ExtraManaCost
#payment interaction (GenericPaidAbility -> MenuAbility optionalCost ->
#game->mExtraPayment) that IGNORES the whole suite vocabulary - choice
#commands are swallowed with no doReactTo, card/player clicks dead -
#and it blocks NextGamePhase FOREVER (the suite hangs re-issuing goto).
#Same machinery as yurlok's old 'payment menu HANGS if choice-driven'
#note. ENGINE ROUND: the mExtraPayment/X-in-pay() flow - either the
#suite needs a payment-drive verb (revealok precedent) or the
#ExtraManaCost-X interaction is broken engine-side too. Entry:
#WaitForExtraPayment in GameObserver::cardClick + ExtraManaCost +
#MenuAbility::reactToChoiceClick's toPay arm.
[INIT]
FIRSTMAIN
[PLAYER1]
inplay:flameblast dragon,iron myr,leaden myr
[PLAYER2]
[DO]
goto attackers
flameblast dragon
iron myr
choice 1
leaden myr
choice 1
next
choice 0
choice 2
p2
goto end
goto end
[ASSERT]
ENDOFTURN
[PLAYER1]
inplay:flameblast dragon,iron myr,leaden myr
tappedinplay:3
[PLAYER2]
life:14
[END]
