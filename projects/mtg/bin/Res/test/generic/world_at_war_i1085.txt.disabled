#World at War (#1085): after the first second main, an extra combat (+main)
#this turn; creatures that attacked untap at its start. Bears attack twice:
#opponent at 16. Rebound exiles the spell on resolution.
[INIT]
firstmain
[PLAYER1]
manapool:{3}{R}{R}
inplay:grizzly bears
[PLAYER2]
[DO]
world at war
goto firstmain
goto firstmain
goto attackers
grizzly bears
next
next
goto secondmain
goto attackers
grizzly bears
next
next
goto end
[ASSERT]
ENDOFTURN
[PLAYER1]
inplay:grizzly bears
exile:world at war
tappedinplay:1
[PLAYER2]
life:16
[END]
