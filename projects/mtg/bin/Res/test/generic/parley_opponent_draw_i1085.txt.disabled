#Parley opponent-leg residual - PARKED witness for the remaining reveal bug.
#Post option-oneshot fix: both parley conditionals fire (counters/tokens),
#my draw works, but the OPPONENT-side reveal's afterrevealed draw never
#happens and their revealed card STRANDS in the (shared, controller-side)
#reveal zone. Lifecycle trace: the second MTGRevealingCards instance
#populates and then never receives another Update with an empty zone (its
#after-construct/removeFromGame lines never fire; suspected external removal
#or shared-zone state). When fixed, enable this: their citadel must return
#to their library and they draw it (hand:darksteel citadel, library:silver myr -> after their
#putback the library order differs; see asserts).
[INIT]
firstmain
[PLAYER1]
manapool:{3}{G}
hand:selvala's enforcer
library:millstone,juggernaut
[PLAYER2]
library:silver myr,darksteel citadel
[DO]
selvala's enforcer
goto firstmain
goto firstmain
choice 0
goto firstmain
choice 1
juggernaut
goto firstmain
goto firstmain
choice 0
goto firstmain
choice 1
darksteel citadel
goto firstmain
goto firstmain
[ASSERT]
FIRSTMAIN
[PLAYER1]
hand:juggernaut
inplay:selvala's enforcer
library:millstone
[PLAYER2]
hand:darksteel citadel
library:silver myr
[END]
